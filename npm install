const express = require('express');
const cors = require('cors');

const app = express();
app.use(express.json());
app.use(cors());

// ── YOUR ANTHROPIC API KEY — keep this secret, never share this file publicly ──
const ANTHROPIC_API_KEY = 'YOUR_ANTHROPIC_API_KEY_HERE';

// Health check
app.get('/', (req, res) => {
  res.json({ status: 'CHAINBLOCKNET API running' });
});

// Proxy endpoint — frontend calls this instead of Anthropic directly
app.post('/api/search', async (req, res) => {
  const { query, priceFilter, compFilter } = req.body;

  if (!query || typeof query !== 'string' || query.trim().length === 0) {
    return res.status(400).json({ error: 'Query is required.' });
  }

  const priceNote = priceFilter === 'low' ? 'Only include products that typically sell for under $20.'
    : priceFilter === 'mid' ? 'Only include products priced between $20–$50.'
    : priceFilter === 'high' ? 'Only include products priced above $50.' : '';

  const compNote = compFilter === 'low' ? 'Only include Low competition products.'
    : compFilter === 'medium' ? 'Include Low and Medium competition products only.' : '';

  const prompt = `You are a world-class Amazon FBA consultant specializing in helping brand new sellers find excellent ungated product opportunities.

User wants ideas around: "${query.trim()}". ${priceNote} ${compNote}

Return ONLY a raw JSON array of exactly 6 objects. No markdown, no backticks, no explanation. Each object must have:
- "name": a very specific product (e.g. "Silicone Collapsible Dog Bowl" not "dog bowl")
- "category": the exact Amazon top-level category
- "why_ungated": one sentence why new sellers can list this freely
- "price_range": typical retail selling price, e.g. "$18–$26"
- "competition": exactly one of: "Low", "Medium", "High"
- "profit_margin": estimated net margin range, e.g. "28–42%"
- "monthly_searches": estimated Amazon monthly searches, e.g. "9,000–14,000"
- "sourcing": where/how to source it (e.g. "Alibaba MOQ 100 units")
- "tip": one specific, actionable beginner tip
- "tags": array of 2–3 short descriptive tags

Only suggest products from truly ungated categories: Home & Kitchen, Office Products, Sports & Outdoors, Patio Lawn & Garden, Pet Supplies, Baby (non-safety), Toys & Games (non-restricted), Arts Crafts & Sewing, Health & Household (non-OTC drugs), Tools & Home Improvement (general), Books, Electronics Accessories.

Never suggest: Grocery, Automotive, Medical devices, Alcohol, Weapons, Trademarked/brand-gated products, Supplements.`;

  try {
    const response = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-api-key': ANTHROPIC_API_KEY,
        'anthropic-version': '2023-06-01'
      },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 2000,
        messages: [{ role: 'user', content: prompt }]
      })
    });

    if (!response.ok) {
      const err = await response.json();
      return res.status(500).json({ error: err.error?.message || 'Anthropic API error' });
    }

    const data = await response.json();
    const text = data.content.map(i => i.text || '').join('');
    const clean = text.replace(/```json|```/g, '').trim();
    const products = JSON.parse(clean);

    res.json({ products });

  } catch (e) {
    res.status(500).json({ error: e.message || 'Server error. Please try again.' });
  }
});

const PORT = process.env.PORT || 3000;
app.listen(PORT, () => {
  console.log(`CHAINBLOCKNET API running on port ${PORT}`);
});
